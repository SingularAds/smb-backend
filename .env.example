# ────────────────────────────────────────────────────────────────────────────
# Recepte — .env.example
# Copy to .env and fill in all CHANGE_ME / placeholder values.
# Keys marked [OPTIONAL] can be left empty if the feature is not used.
# ────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=Recepte
APP_VERSION=1.0.0
# "production" disables debug routes and the local DNS/TLS workarounds.
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO

# Production transport flags — must be False in production.
ALLOW_INSECURE_TRANSPORT=False
ENABLE_SSLIP_DNS_OVERRIDE=False

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── Public base URL ───────────────────────────────────────────────────────────
# Public HTTPS URL of this server (no trailing slash).
# Used to build Google OAuth callback links sent via WhatsApp.
BASE_URL=https://recepte.co

# ── Security ─────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
API_SECRET=CHANGE_ME_same_as_SECRET_KEY

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["https://recepte.co","https://app.recepte.co"]
ALLOWED_METHODS=["GET","POST","PUT","DELETE","PATCH","OPTIONS"]
ALLOWED_HEADERS=["*"]

# ── Firebase / Firestore ──────────────────────────────────────────────────────
# Mount serviceAccount.json into the container at this path.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
FIRESTORE_PROJECT_ID=your-firebase-project-id

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── ElevenLabs TTS ───────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── Google Calendar ───────────────────────────────────────────────────────────
# Service account fallback (used when no OAuth token stored for the owner)
GOOGLE_CREDENTIALS_FILE=./credentials.json
GOOGLE_CALENDAR_ID=primary
# OAuth client credentials (for per-business calendar connect)
GOOGLE_CLIENT_ID=.
GOOGLE_CLIENT_SECRET=
# Must EXACTLY match a registered Redirect URI in Google Cloud Console.
GOOGLE_REDIRECT_URI=https://recepte.co/auth/google/callback

# ── Google Places API ─────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=

# ── Apify (Instagram & Maps scraping) ── [OPTIONAL] ───────────────────────────
# Used for: Instagram business profile enrichment, Google Maps share link fallback
APIFY_API_KEY=
APIFY_INSTAGRAM_ACTOR_ID=apify~instagram-scraper
APIFY_GOOGLE_PLACES_ACTOR_ID=compass~crawler-google-places

# ── Stripe ───────────────────────────────────────────────────────────────────
# Use sk_live_... in production, sk_test_... for staging.
STRIPE_SECRET_KEY=
# Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=

# ── WhatsApp / whatsmeow Bridge ───────────────────────────────────────────────
WHATSMEOW_API_BASE_URL=https://your-bridge-host.example.com
WHATSMEOW_API_USERNAME=
WHATSMEOW_API_PASSWORD=
WHATSMEOW_DEFAULT_DEVICE_ID=smba
WHATSMEOW_ONBOARDING_DEVICE_ID=
WHATSMEOW_GLOBAL_NUMBER=
# Must match the secret configured in the bridge.
WEBHOOK_SECRET=CHANGE_ME_generate_with_secrets_token_urlsafe_32
X_WEBHOOK_SECRET=

# ── Recepte global settings ───────────────────────────────────────────────────
RECEPTE_PHONE=919905252720
RECEPTE_CALENDAR_BASE_URL=https://recepte.co/connect-calendar

# ── VAPI (voice AI) ── [OPTIONAL] ────────────────────────────────────────────
VAPI_SECRET=
VAPI_API_KEY=
VAPI_DEFAULT_ASSISTANT_ID=
VAPI_DEFAULT_BUSINESS_ID=

# ── Speech providers ── [OPTIONAL] ───────────────────────────────────────────
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# ── SMTP ── [OPTIONAL] ───────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=True

# ── Call forwarding ── [OPTIONAL] ────────────────────────────────────────────
# JSON map: {"351": "+351200010001", "1": "+12125550100"}
CALL_FORWARDING_NUMBERS_JSON={}
CALL_FORWARDING_DEFAULT_NUMBER=

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_DAILY_SUMMARIES=True
ENABLE_REMINDERS=True
ENABLE_QA_RUNNER=False

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
